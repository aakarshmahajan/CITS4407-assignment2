#!/usr/bin/env bash

# Name: Aakarsh Sagar Mahajan
# Date: 20 May 2026
#
# clean - reads trending_videos_unclean.csv and outputs a cleaned version
# to stdout. performs 5 error checks on the input file first, then cleans
# the data by removing rows with empty fields, zero likes/dislikes, and
# duplicate rows. also strips the timestamp off publish_date and drops
# the ratings_disabled column entirely.
# Usage: ./clean <inputfile>

# Checking Errors

# 1. no file argument given
if [ $# -eq 0 ]; then
    echo "ERROR: No input CSV file provided"
    exit 1
fi

inputfile="$1"

# 2. file not found in current directory
if [ ! -f "$inputfile" ]; then
    echo "ERROR: Input file not found in the current directory"
    exit 1
fi

# 3. input file must have a .csv extension
if [[ "$inputfile" != *.csv ]]; then
    echo "ERROR: Input file expected in a CSV format"
    exit 1
fi

# 4. file should not be empty
if [ ! -s "$inputfile" ]; then
    echo "ERROR: Empty file provided"
    exit 1
fi

# 5. header must have exactly 7 columns
num_cols=$(head -1 "$inputfile" | awk -F',' '{print NF}')
if [ "$num_cols" -ne 7 ]; then
    echo "ERROR: Expected 7 columns in the header"
    exit 1
fi

#Data Cleaning

# print the new header - ratings_disabled is dropped
echo "video_id,publish_date,views,likes,dislikes,comments_disabled"

# go through each data row and apply all cleaning rules
tail -n +2 "$inputfile" | awk -F',' '
{
    # skip rows that do not have exactly 7 fields
    if (NF != 7) next

    # skip rows with any empty field
    if ($1 == "" || $2 == "" || $3 == "" || $4 == "" || $5 == "" || $6 == "") next

    # skip rows where likes or dislikes are zero
    if ($4 == 0 || $5 == 0) next

    # strip the time from publish_date, keep only YYYY-MM-DD
    split($2, date, "T")

    # print row without ratings_disabled
    print $1 "," date[1] "," $3 "," $4 "," $5 "," $6

}' | sort -u
